# Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# AI Providers
NVIDIA_NIM_API_KEY=
OPENCODE_ZEN_API_KEY=
OPENROUTER_API_KEY=

# AI Models (comma-separated; uncomment to override hardcoded model list for each provider)
# Uncomment and edit the ones you want. Models go through their respective provider API.
#
# NVIDIA NIM models (direct):
# NEXT_PUBLIC_NVIDIA_MODELS=nvidia/nemotron-3-super-free,deepseek-ai/deepseek-v4-flash
#
# OpenCode Zen models (direct):
# NEXT_PUBLIC_OPENCODE_ZEN_MODELS=opencode/deepseek-v4-flash-free
#
# OpenRouter models (proxied — model ID string is passed to OpenRouter API):
# NEXT_PUBLIC_OPENROUTER_MODELS=nvidia/nemotron-3-super-120b-a12b:free,poolside/laguna-m.1:free,openai/gpt-oss-120b:free

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=

# App Check / reCAPTCHA (Firebase App Check protection)
# Get from Google Cloud Console > reCAPTCHA Enterprise
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
NEXT_PUBLIC_RECAPTCHA_ENTERPRISE_SITE_KEY=

# Cron job secret (used by /api/cleanup; generate with: node -e "console.log(require('crypto').randomUUID())")
CRON_SECRET=

# Admin (comma-separated email whitelist)
ADMIN_EMAILS=

# Admin path (change for obfuscation, default: 'admin')
NEXT_PUBLIC_ADMIN_PATH=youradminpath
